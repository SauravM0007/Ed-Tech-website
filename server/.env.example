# MongoDB Atlas connection string
MONGODB_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/study_notion

# JWT
JWT_SECRET=your_jwt_secret

# Cloudinary (required on Vercel — local disk uploads do not persist)
CLOUD_NAME=your_cloud_name
API_KEY=your_api_key
API_SECRET=your_api_secret
# Or use a single URL instead of the three vars above:
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Cloudinary upload folder name
FOLDER_NAME=StudyNotion

# Razorpay
RAZORPAY_KEY=your_razorpay_key
RAZORPAY_SECRET=your_razorpay_secret

# Email (Nodemailer)
MAIL_HOST=smtp.example.com
MAIL_USER=your_email@example.com
MAIL_PASS=your_email_password

# Frontend URL (for CORS and password-reset emails)
CLIENT_URL=https://your-frontend.vercel.app

# Public backend URL (for local upload fallback; use your Vercel backend URL in production)
BASE_URL=https://your-backend.vercel.app
